// Place your settings in this file to overwrite default and user settings.
{
    "files.exclude": {
        "out": false, // set this to true to hide the "out" folder with the compiled JS files
        "dist": false // set this to true to hide the "dist" folder with the compiled JS files
    },
    "search.exclude": {
        "out": true, // set this to false to include "out" folder in search results
        "dist": true // set this to false to include "dist" folder in search results
    },
    // Turn off tsc task auto detection since we have the necessary tasks as npm scripts
    "typescript.tsc.autoDetect": "off",
    "pixel-agents.projectName": "Pixel Agents",

    "workbench.colorCustomizations": {
        "titleBar.activeBackground": "#14141f",
        "titleBar.activeForeground": "#e7e7e7",
        "titleBar.inactiveBackground": "#000000",
        "titleBar.inactiveForeground": "#e7e7e799"
    },
    "workspaceColorPicker.color": "#1e1e2e",
    "workspaceColorPicker.affectTitleBar": true,
    "workspaceColorPicker.affectActivityBar": false,
    "workspaceColorPicker.affectStatusBar": false,
    "workspaceColorPicker.elementAdjustments": {
        "titleBar": -0.2,
        "activityBar": -0.4,
        "statusBar": 0.2,
        "iconContrast": 0.4,
        "iconContrastEnabled": true
    }
}