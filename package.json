{
  "name": "pixel-agents",
  "displayName": "Pixel Agents",
  "description": "Pixel art office where your Claude Code agents come to life as animated characters",
  "version": "1.5.42",
  "publisher": "pablodelucca",
  "repository": {
    "type": "git",
    "url": "https://github.com/pablodelucca/pixel-agents"
  },
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pixel-agents.exportDefaultLayout",
        "title": "Pixel Agents: Export Layout as Default"
      },
      {
        "command": "pixel-agents.openInTab",
        "title": "Pixel Agents: Open Viewer"
      },
      {
        "command": "pixel-agents.setProjectName",
        "title": "Pixel Agents: Set Project Name"
      },
      {
        "command": "pixel-agents.showMissingSprites",
        "title": "Pixel Agents: Show Missing Bubble Sprites"
      },
      {
        "command": "pixel-agents.restartStandalone",
        "title": "Pixel Agents: Restart Standalone Server"
      }
    ],
    "configuration": {
      "title": "Pixel Agents",
      "properties": {
        "pixel-agents.projectName": {
          "type": "string",
          "default": "",
          "description": "Custom project name displayed on agent nametags. Leave empty to use the workspace folder name."
        },
        "pixel-agents.standalonePort": {
          "type": "number",
          "default": 7600,
          "description": "Port for the standalone Pixel Agents viewer server."
        },
        "pixel-agents.relayUrl": {
          "type": "string",
          "default": "",
          "description": "WebSocket URL for the remote relay server. Leave empty to disable."
        },
        "pixel-agents.relayToken": {
          "type": "string",
          "default": "",
          "description": "Authentication token for the remote relay server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build:webview": "cd webview-ui && npm run build",
    "compile": "npm run check-types && npm run lint && node esbuild.js && npm run build:webview",
    "build": "npm run compile",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production && npm run build:webview",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "import-tileset": "tsx scripts/0-import-tileset.ts",
    "standalone": "node standalone/server.mjs",
    "relay": "node relay/server.mjs"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@types/node": "22.x",
    "@types/pngjs": "^6.0.5",
    "@types/vscode": "^1.107.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
